# Server Configuration
PORT=5000

# Database Configuration (MySQL)
# Example Local: DATABASE_URL="mysql://root:mypassword@localhost:3306/hostelfood"
# Example Aiven Cloud: DATABASE_URL="mysql://avnadmin:yourpassword@your-aiven-host:port/defaultdb?ssl-mode=REQUIRED"

# Replace this with the actual Aiven Cloud connection string
DATABASE_URL="mysql://username:password@host:port/database?ssl-mode=REQUIRED"

# Set this to "true" when connecting to Aiven Cloud or any DB requiring SSL
DB_REQUIRE_SSL="true"

# JWT Secrets for Authentication
JWT_ACCESS_SECRET="your_super_secret_access_key_here"
JWT_REFRESH_SECRET="your_super_secret_refresh_key_here"
